SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# Auth (obrigatório em produção)
# Pegue no Google Cloud Console: APIs & Services > Credentials > OAuth Client ID
GOOGLE_CLIENT_ID=123456-abc.apps.googleusercontent.com
# String aleatória de 32+ caracteres pra assinar JWT da sessão
SESSION_SECRET=mude-isso-em-producao-use-uma-string-aleatoria
# Allowlist por domínio (vírgula-separado) — só @seazone.com.br por exemplo
ALLOWED_DOMAINS=seazone.com.br
# Allowlist adicional por email completo (opcional)
ALLOWED_EMAILS=victoria@hofmeisteradv.com.br
# CORS (vazio = aceita qualquer origem)
CORS_ORIGIN=https://seazone-assembleias.onrender.com
